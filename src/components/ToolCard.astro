---
interface Props {
  title: string;
  description: string;
  href: string;
  tag?: string;
}

const { title, description, href, tag } = Astro.props;
---

<a href={href} class="group relative block p-8 border border-gray-100 rounded-2xl bg-white hover:border-gray-200 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden">
  <!-- Background gradient on hover -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-purple-50 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  
  <div class="relative">
    <div class="flex items-start justify-between mb-4">
      <h3 class="text-xl font-semibold group-hover:text-gray-900 transition-colors">
        {title}
      </h3>
      <svg width="20" height="20" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-400 group-hover:text-gray-900 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
        <path d="M4 12L12 4M12 4H5M12 4v7"/>
      </svg>
    </div>
    <p class="text-gray-600 leading-relaxed">
      {description}
    </p>
    {tag && (
      <span class="absolute top-0 right-0 px-3 py-1 text-xs font-semibold rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white">
        {tag}
      </span>
    )}
  </div>
</a>
