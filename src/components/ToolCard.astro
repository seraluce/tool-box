---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon = '→' } = Astro.props;
---

<a href={href} class="group block p-6 border border-[var(--border)] rounded-lg hover:border-[var(--foreground)] transition-all duration-200">
  <div class="flex items-start justify-between">
    <div class="flex-1">
      <h3 class="text-base font-medium mb-2 group-hover:text-[var(--accent)] transition-colors">
        {title}
      </h3>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
        {description}
      </p>
    </div>
    <span class="text-xl text-[var(--muted-foreground)] group-hover:text-[var(--foreground)] group-hover:translate-x-1 transition-all">
      {icon}
    </span>
  </div>
</a>
