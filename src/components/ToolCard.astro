---
interface Props {
  title: string;
  description: string;
  href: string;
  tag?: string;
}

const { title, description, href, tag } = Astro.props;
---

<a href={href} class="group relative block p-6 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-foreground)]/30 hover:shadow-sm transition-all duration-200">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-[15px] font-semibold group-hover:text-[var(--color-accent)] transition-colors">
      {title}
    </h3>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-muted-foreground)] group-hover:text-[var(--color-foreground)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all">
      <path d="M4 12L12 4M12 4H5M12 4v7"/>
    </svg>
  </div>
  <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">
    {description}
  </p>
  {tag && (
    <span class="absolute top-3 right-3 px-1.5 py-0.5 text-[10px] font-medium rounded bg-[var(--color-accent)] text-white">
      {tag}
    </span>
  )}
</a>
