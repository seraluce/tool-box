---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n/index';

const t = getTranslations('zh');

const features = [
  { title: t.home.feature1Title, description: t.home.feature1Desc, icon: 'bolt' },
  { title: t.home.feature2Title, description: t.home.feature2Desc, icon: 'design' },
  { title: t.home.feature3Title, description: t.home.feature3Desc, icon: 'refresh' },
];
---

<BaseLayout 
  title="ToolBox - 简洁实用的在线工具集合"
  description="精心打造的在线小工具集合，包含 Steam 卡片生成器等实用工具。无需安装，打开即用，让你的工作更高效。"
  keywords="在线工具,Steam卡片,工具集合,ToolBox,实用工具,效率工具"
  lang="zh"
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 dark:bg-purple-900 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-70 animate-blob"></div>
      <div class="absolute top-0 -right-4 w-72 h-72 bg-yellow-300 dark:bg-yellow-900 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
      <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-300 dark:bg-pink-900 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
    </div>

    <div class="absolute inset-0 -z-10 opacity-[0.03] dark:opacity-[0.05]">
      <div class="absolute inset-0" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 50px 50px;"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-20 relative">
      <div class="text-center max-w-4xl mx-auto">
        <div class="animate-fade-in inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm text-sm text-gray-600 dark:text-gray-300 mb-8 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          {t.home.badge}
        </div>

        <h1 class="animate-fade-in-up text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-8">
          <span class="block">{t.home.titleLine1}</span>
          <span class="block gradient-text animate-gradient mt-2">{t.home.titleLine2}</span>
        </h1>

        <p class="animate-fade-in-up animation-delay-200 text-xl sm:text-2xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
          {t.home.desc}<br class="hidden sm:block" />
          {t.home.desc2}
        </p>

        <div class="animate-fade-in-up animation-delay-400 flex items-center justify-center">
          <a href="#tools" class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-black dark:bg-white text-white dark:text-black font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            <span>{t.home.cta}</span>
            <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v10M3 8l5 5 5-5"/></svg>
          </a>
        </div>

        <div class="absolute top-1/4 left-10 w-20 h-20 bg-gradient-to-br from-blue-400 to-purple-500 rounded-lg opacity-20 animate-float hidden lg:block"></div>
        <div class="absolute bottom-1/4 right-10 w-16 h-16 bg-gradient-to-br from-pink-400 to-red-500 rounded-full opacity-20 animate-float animation-delay-200 hidden lg:block"></div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">{t.home.whyTitle}</h2>
      <p class="text-lg text-gray-600 dark:text-gray-400">{t.home.whySub}</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <div class={`group relative p-8 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-gray-200 dark:hover:border-gray-700 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 animate-fade-in-up`} style={`animation-delay: ${index * 0.1}s`}>
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gray-900 to-gray-700 dark:from-gray-100 dark:to-gray-300 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            {feature.icon === 'bolt' && (
              <svg class="w-6 h-6 text-white dark:text-gray-900" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 1.5L3 9h4.5l-1 5.5L13 7H8.5l1-5.5z"/></svg>
            )}
            {feature.icon === 'design' && (
              <svg class="w-6 h-6 text-white dark:text-gray-900" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12M6 6v8"/></svg>
            )}
            {feature.icon === 'refresh' && (
              <svg class="w-6 h-6 text-white dark:text-gray-900" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8a6 6 0 0111.5-2.5M14 8a6 6 0 01-11.5 2.5"/><path d="M14 2v3.5h-3.5M2 14v-3.5h3.5"/></svg>
            )}
          </div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools Section -->
  <section id="tools" class="max-w-6xl mx-auto px-6 py-24 border-t border-gray-100 dark:border-gray-800">
    <div class="mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">工具</h2>
      <p class="text-lg text-gray-600 dark:text-gray-400">所有可用的在线工具</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/tools/steam-card" class="group relative p-8 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-gray-200 dark:hover:border-gray-700 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-lg font-semibold">Steam 卡片生成器</h3>
          <span class="px-2 py-0.5 text-[11px] font-medium rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">热门</span>
        </div>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm">快速生成你的 Steam 资料卡片，支持多主题、自定义背景、统计信息等</p>
        <div class="mt-4 flex items-center gap-1 text-sm text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors">
          <span>打开</span>
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12L12 4M12 4H5M12 4v7"/></svg>
        </div>
      </a>

      <div class="group relative p-8 border-2 border-dashed border-gray-200 dark:border-gray-700 rounded-2xl opacity-60 hover:opacity-80 transition-opacity">
        <div class="flex flex-col gap-3">
          <h3 class="text-lg font-medium text-gray-400">更多工具</h3>
          <p class="text-gray-400 leading-relaxed text-sm">正在开发中，敬请期待...</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 to-black dark:from-gray-800 dark:to-gray-900 -z-10"></div>
    <div class="max-w-6xl mx-auto px-6 py-24 relative">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 text-white">{t.home.ctaTitle}</h2>
        <p class="text-lg text-gray-300 mb-8 leading-relaxed">{t.home.ctaDesc}</p>
      </div>
    </div>
  </section>
</BaseLayout>
