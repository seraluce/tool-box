---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = [
  {
    title: 'Steam 卡片生成器',
    description: '快速生成你的 Steam 资料卡片，支持自定义样式和预设配置',
    href: '/tools/steam-card',
    icon: '🎮',
  },
];
---

<BaseLayout title="ToolBox - 在线工具集合">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <div class="mb-16">
      <h1 class="text-4xl font-bold tracking-tight mb-4">
        在线工具集合
      </h1>
      <p class="text-lg text-[var(--muted-foreground)] max-w-2xl">
        简洁实用的在线工具，让你的工作更高效
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((tool) => (
        <ToolCard
          title={tool.title}
          description={tool.description}
          href={tool.href}
          icon={tool.icon}
        />
      ))}
    </div>
  </div>
</BaseLayout>
