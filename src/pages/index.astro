---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = [
  {
    title: 'Steam 卡片生成器',
    description: '快速生成你的 Steam 资料卡片，支持多主题、自定义背景、统计信息等',
    href: '/tools/steam-card',
    tag: '热门',
  },
];

const features = [
  {
    title: '开箱即用',
    description: '无需注册登录，打开浏览器即可使用所有工具',
    icon: 'bolt',
  },
  {
    title: '极简设计',
    description: '扁平化 UI 设计，专注功能本身，拒绝花哨',
    icon: 'design',
  },
  {
    title: '持续更新',
    description: '不断添加新的实用工具，满足你的日常需求',
    icon: 'refresh',
  },
];
---

<BaseLayout title="ToolBox - 在线工具集合">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Grid Background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0" style="background-image: linear-gradient(var(--color-border) 1px, transparent 1px), linear-gradient(90deg, var(--color-border) 1px, transparent 1px); background-size: 64px 64px; opacity: 0.4;"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 50% at 50% 0%, transparent 40%, var(--color-background) 100%);"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
      <div class="text-center max-w-3xl mx-auto">
        <!-- Badge -->
        <div class="animate-fade-in inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border)] bg-white text-[13px] text-[var(--color-muted-foreground)] mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
          持续更新中
        </div>

        <!-- Title -->
        <h1 class="animate-fade-in-delay-1 text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
          简洁实用的
          <br />
          <span class="bg-gradient-to-r from-[var(--color-foreground)] via-[var(--color-muted-foreground)] to-[var(--color-foreground)] bg-clip-text text-transparent">
            在线工具集合
          </span>
        </h1>

        <!-- Description -->
        <p class="animate-fade-in-delay-2 text-lg sm:text-xl text-[var(--color-muted-foreground)] max-w-xl mx-auto mb-10 leading-relaxed">
          精心打造的在线小工具，每一个都简洁高效。<br class="hidden sm:block" />
          无需安装，打开即用。
        </p>

        <!-- CTA -->
        <div class="animate-fade-in-delay-3 flex items-center justify-center gap-3">
          <a href="#tools" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-foreground)] text-white text-sm font-medium hover:opacity-90 transition-opacity">
            开始使用
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3v10M3 8l5 5 5-5"/></svg>
          </a>
          <a href="https://github.com/seraluce/tool-box" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium hover:bg-[var(--color-muted)] transition-colors">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            源代码
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[var(--color-background)] to-transparent"></div>
  </section>

  <!-- Features Section -->
  <section class="max-w-6xl mx-auto px-6 py-16 border-t border-[var(--color-border)]">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="flex flex-col gap-3">
          <div class="w-9 h-9 rounded-lg border border-[var(--color-border)] flex items-center justify-center">
            {feature.icon === 'bolt' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 1.5L3 9h4.5l-1 5.5L13 7H8.5l1-5.5z"/></svg>
            )}
            {feature.icon === 'design' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12M6 6v8"/></svg>
            )}
            {feature.icon === 'refresh' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 8a6 6 0 0111.5-2.5M14 8a6 6 0 01-11.5 2.5"/><path d="M14 2v3.5h-3.5M2 14v-3.5h3.5"/></svg>
            )}
          </div>
          <h3 class="text-sm font-semibold">{feature.title}</h3>
          <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools Section -->
  <section id="tools" class="max-w-6xl mx-auto px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mb-10">
      <h2 class="text-2xl font-bold tracking-tight mb-2">工具</h2>
      <p class="text-sm text-[var(--color-muted-foreground)]">所有可用的在线工具</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((tool) => (
        <ToolCard
          title={tool.title}
          description={tool.description}
          href={tool.href}
          tag={tool.tag}
        />
      ))}

      <!-- Coming Soon Card -->
      <div class="group p-6 border border-dashed border-[var(--color-border)] rounded-lg opacity-60">
        <div class="flex items-start justify-between">
          <div class="flex-1">
            <h3 class="text-base font-medium mb-2 text-[var(--color-muted-foreground)]">
              更多工具
            </h3>
            <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">
              正在开发中，敬请期待...
            </p>
          </div>
          <span class="text-sm text-[var(--color-muted-foreground)]">
            ...
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="max-w-6xl mx-auto px-6 py-20 border-t border-[var(--color-border)]">
    <div class="text-center max-w-lg mx-auto">
      <h2 class="text-2xl font-bold tracking-tight mb-3">有工具建议？</h2>
      <p class="text-sm text-[var(--color-muted-foreground)] mb-6 leading-relaxed">
        如果你有任何工具需求或建议，欢迎在 GitHub 上提交 Issue 或 Pull Request
      </p>
      <a href="https://github.com/seraluce/tool-box/issues" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium hover:bg-[var(--color-muted)] transition-colors">
        提交建议
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12L12 4M12 4H5M12 4v7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
